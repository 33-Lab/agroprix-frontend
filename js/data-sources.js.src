//    AP.DataSources.getMarketPrices({ country:'cote_divoire', product:'cacao', source:'wfp' })
//      .then(function(prices) { console.log(prices); });
//
// 3. Comparatif régional du mil (8 pays UEMOA) :
//    AP.DataSources.getRegionalComparison('mil')
//      .then(function(prices) {
//        var stats = AP.DataSources.getPriceStats(prices);
//        console.log('Écart de prix régional :', stats.spread, 'XOF/kg');
//        console.log('Meilleur marché :', stats.bestMarket);
//      });
//
// 4. Vérifier la disponibilité des sources :
//    console.log(AP.DataSources.SOURCES);
// ============================================================
